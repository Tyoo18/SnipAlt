{
  "manifest_version": 3,
  "name": "SnipAlt",
  "version": "1.0.0",
  "description": "The fastest way to save web insights without breaking your flow.",
  "permissions": ["storage", "sidePanel", "activeTab", "contextMenus"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["src/content/index.tsx"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "commands": {
    "capture-snippet": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Capture selected text snippet instantly"
    }
  },
  "action": {
    "default_title": "Open SnipAlt Side Panel"
  },
  "icons": {
    "16": "src/assets/icons16.png",
    "48": "src/assets/icons48.png",
    "128": "src/assets/icons128.png"
  }
}
